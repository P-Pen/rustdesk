[Unit]
Description=PNDesk
Requires=network.target
After=systemd-user-sessions.service

[Service]
Type=simple
ExecStart=/usr/bin/pndesk --service
# kill --tray and --server both
ExecStop=pkill -f "pndesk --"
# below two lines do not work, have to use above one line
#ExecStop=pkill -f "pndesk --tray"
#ExecStop=pkill -f "pndesk --server"
PIDFile=/run/pndesk.pid
KillMode=mixed
TimeoutStopSec=30
User=root
LimitNOFILE=100000

[Install]
WantedBy=multi-user.target
